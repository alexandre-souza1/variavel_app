<div>
  <div class="container p-3">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="mb-0"><i class="bi bi-card-list"> </i>Mapas Cadastrados</h1>
      </div>
      <div class="col-md-4 text-md-end d-flex flex-row-reverse">
        <p class="font-weight-light">LOG20 - Foz do Iguaçu</p>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- Card de resumo -->
    <div class="card shadow-sm rounded mb-4">
      <div class="card-body">
        <div class="row align-items-center">
          <div class="col-md-6">
            <h2 class="mb-1">
              <i class="bi bi-calendar-date"></i>
              <%= @data_inicio.present? ? I18n.l(@data_inicio, format: :mes_ano) : "-" %> a
              <%= @data_fim.present? ? I18n.l(@data_fim, format: :mes_ano) : "-" %>
            </h2>
            <p class="text-muted mb-0">
              Total de Mapas: <%= @mapas.size %>
            </p>
          </div>
          <div class="col-md-6 text-md-end">
            <% if current_user.admin? %>
              <%= button_to "Apagar todos os mapas", destroy_all_mapas_path, method: :delete, data: { turbo_confirm: "Tem certeza que deseja apagar TODOS os mapas?" }, class: "btn btn-danger" %>
            <% end %>
            <% if @data_inicio && @data_fim && @dias_periodo %>
              <p class="mb-1"><strong>Período:</strong> <%= @data_inicio.strftime("%d/%m/%Y") %> a <%= @data_fim.strftime("%d/%m/%Y") %></p>
              <p class="mb-0"><strong>Dias:</strong> <%= @dias_periodo %></p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Accordion de Pastas com Filtros -->
    <div class="card shadow-sm rounded mb-4">
      <div class="card-header bg-light border-bottom">
        <h5 class="mb-0"><i class="bi bi-folder-fill me-2"></i>Pastas por Mês</h5>
      </div>
      <div data-controller="mapas-filter delete-maps" class="card-body">
        <!-- Filtros Stimulus -->
        <div class="row mb-3">
          <div class="col-12 col-md-2">
            <input type="text" data-mapas-filter-target="mapa" data-action="input->mapas-filter#filter" class="form-control" placeholder="Filtrar por Mapa">
          </div>
          <div class="col-12 col-md-2">
            <input type="text" data-mapas-filter-target="motorista" data-action="input->mapas-filter#filter" class="form-control" placeholder="Filtrar por Matrícula Motorista">
          </div>
          <div class="col-12 col-md-2">
            <input type="text" data-mapas-filter-target="data" data-action="input->mapas-filter#filter" class="form-control" placeholder="Filtrar por Data (dd/mm/yyyy)">
          </div>
          <div class="col-12 col-md-2">
            <input type="text" data-mapas-filter-target="ajudante" data-action="input->mapas-filter#filter" class="form-control" placeholder="Filtrar por Matrícula Ajudante">
          </div>
          <div class="col-12 col-md-2">
            <select data-mapas-filter-target="mes" data-action="change->mapas-filter#filter" class="form-control">
              <option value="">Todos os Meses</option>
              <option value="01">Janeiro</option>
              <option value="02">Fevereiro</option>
              <option value="03">Março</option>
              <option value="04">Abril</option>
              <option value="05">Maio</option>
              <option value="06">Junho</option>
              <option value="07">Julho</option>
              <option value="08">Agosto</option>
              <option value="09">Setembro</option>
              <option value="10">Outubro</option>
              <option value="11">Novembro</option>
              <option value="12">Dezembro</option>
            </select>
          </div>
          <div class="col-12 col-md-2">
            <select data-mapas-filter-target="ano" data-action="change->mapas-filter#filter" class="form-control">
              <option value="">Todos os Anos</option>
              <option value="2025">2025</option>
              <option value="2026">2026</option>
            </select>
          </div>
        </div>

        <%= form_with url: bulk_delete_mapas_path, method: :delete, data: { turbo: false }, html: { onsubmit: "return confirm('Tem certeza que deseja apagar os mapas selecionados?');" } do |f| %>

          <!-- Accordion -->
          <div class="accordion" id="accordionMapas">
            <% @mapas_por_mes.each_with_index do |(ano_mes, mapas_do_mes), index| %>
              <% ano, mes = ano_mes %>
              <% mes_nome = nome_mes_ano(ano, mes) %>

              <div class="accordion-item" data-mapas-filter-target="folder">
                <h2 class="accordion-header" id="heading<%= index %>">
                  <button class="accordion-button <%= 'collapsed' if index > 0 %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= index %>" aria-expanded="<%= index == 0 ? 'true' : 'false' %>" aria-controls="collapse<%= index %>">
                    <strong><%= mes_nome %></strong>
                    <span class="badge bg-secondary ms-3"><%= mapas_do_mes.size %> mapas</span>
                    <span class="badge bg-danger ms-2" data-delete-maps-target="counter" style="display: none;">0 selecionados</span>
                  </button>
                </h2>
                <div id="collapse<%= index %>" class="accordion-collapse collapse <%= 'show' if index == 0 %>" aria-labelledby="heading<%= index %>" data-bs-parent="#accordionMapas">
                  <div class="accordion-body">
                    <div class="table-responsive">
                      <table class="table table-hover align-middle">
                        <thead class="table-light">
                          <tr>
                            <th width="50px">
                              <input type="checkbox"
                                     data-delete-maps-target="selectAll"
                                     data-action="change->delete-maps#toggleAll"
                                     class="form-check-input">
                            </th>
                            <th>Mapa</th>
                            <th>Data</th>
                            <th>Matricula Motorista</th>
                            <th>Matricula Ajudante1</th>
                            <th>Matricula Ajudante2</th>
                            <th>Fator</th>
                            <th>Cx Total</th>
                            <th>Cx Real</th>
                            <th>PDV Total</th>
                            <th>PDV Real</th>
                            <th>Recarga</th>
                            <th>Placa</th>
                            <th>Ações</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% mapas_do_mes.each do |mapa| %>
                            <tr data-mapas-filter-target="row">
                              <td>
                                <input type="checkbox"
                                       name="mapa_ids[]"
                                       value="<%= mapa.id %>"
                                       data-delete-maps-target="mapaCheckbox"
                                       data-action="change->delete-maps#updateSelection"
                                       class="form-check-input">
                              </td>
                              <td><%= mapa.mapa %></td>
                              <td><%= mapa.data_formatada&.strftime("%d/%m/%Y") || "Data inválida" %></td>
                              <td><%= mapa.matric_motorista %></td>
                              <td><%= mapa.matric_ajudante %></td>
                              <td><%= mapa.matric_ajudante_2 %></td>
                              <td><%= mapa.fator %></td>
                              <td><%= mapa.cx_total %></td>
                              <td><%= mapa.cx_real %></td>
                              <td><%= mapa.pdv_total %></td>
                              <td><%= mapa.pdv_real %></td>
                              <td><%= mapa.recarga %></td>
                              <td><%= mapa.plate %></td>
                              <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group">
                                  <%= link_to 'Editar', edit_mapa_path(mapa), class: 'btn btn-outline-primary' %>
                                  <%= link_to 'Excluir', mapa_path(mapa), data: { turbo_method: :delete, turbo_confirm: 'Tem certeza?' }, class: 'btn btn-outline-danger' %>
                                </div>
                              </td>
                            </tr>
                          <% end %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Botão de apagar selecionados (global) -->
          <% if current_user.admin? %>
            <div class="d-flex justify-content-between mt-3">
              <%= f.submit "Apagar selecionados",
                  data: { delete_maps_target: "deleteSelectedBtn" },
                  disabled: true,
                  class: "btn btn-danger" %>
            </div>
          <% end %>

        <% end %>

        <%= link_to "Voltar", root_path, class: "btn btn-primary shadow-sm p-3 w-100 mt-2" %>
      </div>
    </div>
  </div>
</div>
