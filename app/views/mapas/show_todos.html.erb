<div>
  <div class="container p-3">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="mb-0"><i class="bi bi-card-list"> </i>Mapas Cadastrados</h1>
      </div>
      <div class="col-md-4 text-md-end d-flex flex-row-reverse">
        <p class="font-weight-light">LOG20 - Foz do Iguaçu</p>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- Card de resumo -->
    <div class="card shadow-sm rounded mb-4">
      <div class="card-body">
        <div class="row align-items-center">
          <div class="col-md-6">
            <h2 class="mb-1">
              <i class="bi bi-calendar-date"></i>
              <%= @data_inicio.present? ? I18n.l(@data_inicio, format: :mes_ano) : "-" %> a
              <%= @data_fim.present? ? I18n.l(@data_fim, format: :mes_ano) : "-" %>
            </h2>
            <p class="text-muted mb-0">
              Total de Mapas: <%= @total_mapas %>
            </p>
          </div>
          <div class="col-md-6 text-md-end">
            <% if current_user.admin? %>
              <%= button_to "Apagar todos os mapas", destroy_all_mapas_path, method: :delete, data: { turbo_confirm: "Tem certeza que deseja apagar TODOS os mapas?" }, class: "btn btn-danger" %>
            <% end %>
            <% if @data_inicio && @data_fim && @dias_periodo %>
              <p class="mb-1"><strong>Período exibido:</strong> <%= @data_inicio.strftime("%d/%m/%Y") %> a <%= @data_fim.strftime("%d/%m/%Y") %></p>
              <p class="mb-0"><strong>Dias:</strong> <%= @dias_periodo %></p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Lista de mapas com filtros -->
    <div class="card shadow-sm rounded mb-4">
      <div class="card-header bg-light border-bottom">
        <h5 class="mb-0"><i class="bi bi-table me-2"></i>Lista de Mapas</h5>
      </div>
      <div data-controller="delete-maps" class="card-body">
        <%= form_with url: mapas_todos_path, method: :get, local: true, class: "row mb-3 g-2 align-items-end" do |f| %>
          <%= f.hidden_field :page, value: 1 %>
          <div class="col-12 col-md-2">
            <%= f.text_field :mapa, value: params[:mapa], class: "form-control", placeholder: "Filtrar por Mapa" %>
          </div>
          <div class="col-12 col-md-2">
            <%= f.text_field :motorista, value: params[:motorista], class: "form-control", placeholder: "Filtrar por Motorista" %>
          </div>
          <div class="col-12 col-md-2">
            <%= f.text_field :data, value: params[:data], class: "form-control", placeholder: "Data (dd/mm/yyyy)" %>
          </div>
          <div class="col-12 col-md-2">
            <%= f.text_field :ajudante, value: params[:ajudante], class: "form-control", placeholder: "Filtrar por Ajudante" %>
          </div>
          <div class="col-12 col-md-2">
            <%= f.select :mes, options_for_select([
              ["Todos os Meses", ""],
              ["Janeiro", "01"],
              ["Fevereiro", "02"],
              ["Março", "03"],
              ["Abril", "04"],
              ["Maio", "05"],
              ["Junho", "06"],
              ["Julho", "07"],
              ["Agosto", "08"],
              ["Setembro", "09"],
              ["Outubro", "10"],
              ["Novembro", "11"],
              ["Dezembro", "12"]
            ], params[:mes]), {}, class: "form-control" %>
          </div>
          <div class="col-12 col-md-1">
            <%= f.select :ano, options_for_select([["Todos", ""], ["2025", "2025"], ["2026", "2026"]], params[:ano]), {}, class: "form-control" %>
          </div>
          <div class="col-12 col-md-1 d-grid">
            <%= f.submit "Filtrar", class: "btn btn-primary" %>
          </div>
          <div class="col-12 d-flex justify-content-between align-items-center">
            <%= link_to "Limpar filtros", mapas_todos_path, class: "btn btn-outline-secondary btn-sm" %>
            <span class="text-muted small">Exibindo <%= @mapas.size %> de <%= @total_mapas %> mapas</span>
          </div>
        <% end %>

        <%= form_with url: bulk_delete_mapas_path, method: :delete, data: { turbo: false }, html: { onsubmit: "return confirm('Tem certeza que deseja apagar os mapas selecionados?');" } do |f| %>

          <div class="table-responsive">
            <% if @mapas.empty? %>
              <div class="alert alert-info mb-0">Nenhum mapa encontrado.</div>
            <% else %>
              <table class="table table-hover align-middle">
                <thead class="table-light">
                  <tr>
                    <th width="50px">
                      <input type="checkbox"
                             data-delete-maps-target="selectAll"
                             data-action="change->delete-maps#toggleAll"
                             class="form-check-input">
                    </th>
                    <th>Mapa</th>
                    <th>Data</th>
                    <th>Matricula Motorista</th>
                    <th>Matricula Ajudante1</th>
                    <th>Matricula Ajudante2</th>
                    <th>Fator</th>
                    <th>Cx Total</th>
                    <th>Cx Real</th>
                    <th>PDV Total</th>
                    <th>PDV Real</th>
                    <th>Recarga</th>
                    <th>Placa</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% @mapas.each do |mapa| %>
                    <tr>
                      <td>
                        <input type="checkbox"
                               name="mapa_ids[]"
                               value="<%= mapa.id %>"
                               data-delete-maps-target="mapaCheckbox"
                               data-action="change->delete-maps#updateSelection"
                               class="form-check-input">
                      </td>
                      <td><%= mapa.mapa %></td>
                      <td><%= mapa.data_formatada&.strftime("%d/%m/%Y") || "Data inválida" %></td>
                      <td><%= mapa.matric_motorista %></td>
                      <td><%= mapa.matric_ajudante %></td>
                      <td><%= mapa.matric_ajudante_2 %></td>
                      <td><%= mapa.fator %></td>
                      <td><%= mapa.cx_total %></td>
                      <td><%= mapa.cx_real %></td>
                      <td><%= mapa.pdv_total %></td>
                      <td><%= mapa.pdv_real %></td>
                      <td><%= mapa.recarga %></td>
                      <td><%= mapa.plate %></td>
                      <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group">
                          <%= link_to 'Editar', edit_mapa_path(mapa), class: 'btn btn-outline-primary' %>
                          <%= link_to 'Excluir', mapa_path(mapa), data: { turbo_method: :delete, turbo_confirm: 'Tem certeza?' }, class: 'btn btn-outline-danger' %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            <% end %>
          </div>

          <!-- Botão de apagar selecionados (global) -->
          <% if current_user.admin? %>
            <div class="d-flex justify-content-between mt-3">
              <%= f.submit "Apagar selecionados",
                  data: { delete_maps_target: "deleteSelectedBtn" },
                  disabled: true,
                  class: "btn btn-danger" %>
            </div>
          <% end %>

        <% end %>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mt-3">
          <%= form_with url: mapas_todos_path, method: :get, local: true, class: "d-flex align-items-center gap-2" do |f| %>
            <% request.query_parameters.except(:per_page, :page).each do |key, value| %>
              <%= hidden_field_tag key, value %>
            <% end %>
            <%= hidden_field_tag :page, 1 %>
            <label for="per_page" class="form-label mb-0 text-muted small">Mapas por página</label>
            <%= select_tag :per_page,
                options_for_select([["50", 50], ["100", 100], ["200", 200], ["500", 500]], @per_page),
                class: "form-select form-select-sm w-auto",
                onchange: "this.form.submit()" %>
          <% end %>

          <% if @total_pages > 1 %>
            <nav aria-label="Paginação dos mapas">
              <ul class="pagination justify-content-center flex-wrap">
                <li class="page-item <%= 'disabled' if @page <= 1 %>">
                  <% if @page <= 1 %>
                    <span class="page-link">Anterior</span>
                  <% else %>
                    <%= link_to "Anterior", mapas_todos_path(request.query_parameters.merge(page: @page - 1)), class: "page-link" %>
                  <% end %>
                </li>

                <% ([1, @page - 2].max..[@total_pages, @page + 2].min).each do |page| %>
                  <li class="page-item <%= 'active' if page == @page %>">
                    <%= link_to page, mapas_todos_path(request.query_parameters.merge(page: page)), class: "page-link" %>
                  </li>
                <% end %>

                <li class="page-item <%= 'disabled' if @page >= @total_pages %>">
                  <% if @page >= @total_pages %>
                    <span class="page-link">Próxima</span>
                  <% else %>
                    <%= link_to "Próxima", mapas_todos_path(request.query_parameters.merge(page: @page + 1)), class: "page-link" %>
                  <% end %>
                </li>
              </ul>
              <p class="text-center text-muted small mb-0">Página <%= @page %> de <%= @total_pages %></p>
            </nav>
          <% end %>
        </div>

        <%= link_to "Voltar", root_path, class: "btn btn-primary shadow-sm p-3 w-100 mt-2" %>
      </div>
    </div>
  </div>
</div>
