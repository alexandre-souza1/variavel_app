<div class="container py-5">

  <div class="card shadow-sm">

    <div class="card-body text-center">

      <h2 class="mb-3">
        Checklist em andamento encontrado
      </h2>

      <p class="text-muted mb-4">
        Você possui um checklist não finalizado.
      </p>

      <div class="d-grid gap-3">

        <%= link_to "Continuar Checklist",
              edit_checklist_path(@checklist),
              class: "btn btn-primary btn-lg" %>

        <%= button_to "Recomeçar Checklist",
              restart_checklist_path(@checklist),
              method: :post,
              form: {
                data: {
                  turbo_confirm:
                    "Tem certeza? Todo o progresso será perdido."
                }
              },
              class: "btn btn-outline-danger btn-lg" %>

      </div>

    </div>

  </div>

</div>