<div
  class="card shadow-sm mb-4"
  data-controller="photo-card"
  data-photo-card-target="card">

  <div class="card-body">

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="mb-0">Foto</h5>

      <button
        type="button"
        class="btn btn-sm btn-outline-danger"
        data-action="photo-checklist#removePhoto">

        Remover
      </button>
    </div>

    <%= f.hidden_field :_destroy,
          value: false,
          data: {
            photo_card_target: "destroyInput"
          } %>

    <div class="mb-3">

      <%= f.file_field :photo,
            class: "d-none",
            accept: "image/*",
            capture: "environment",
            direct_upload: true,
            data: {
              photo_card_target: "input",
              action: "change->photo-card#preview"
            } %>

      <button
        type="button"
        class="btn btn-primary btn-lg w-100"
        data-photo-card-target="pickButton"
        data-action="photo-card#openFilePicker">

        📷 Abrir câmera

      </button>

    </div>

    <img
      src="<%= url_for(f.object.photo) if f.object.photo.attached? %>"
      class="img-fluid rounded mb-3 <%= "d-none" unless f.object.photo.attached? %>"
      data-photo-card-target="preview">

    <div
      class="d-none d-grid gap-2 mb-3"
      data-photo-card-target="replaceActions">

      <button
        type="button"
        class="btn btn-outline-primary"
        data-action="photo-card#openFilePicker">

        Trocar foto

      </button>

      <button
        type="button"
        class="btn btn-outline-secondary"
        data-action="photo-card#clearPhoto">

        Limpar seleção

      </button>

    </div>

    <%= f.label :kind, "Tipo da Foto" %>

    <%= f.select :kind,
          options_for_select([
            ["Foto padrão", "standard"],
            ["Defeito encontrado", "defect"]
          ]),
          {},
          class: "form-select mb-3",
          data: {
            action: "change->photo-card#toggleDescription",
            photo_card_target: "kind"
          } %>

    <div
      class="d-none"
      data-photo-card-target="descriptionContainer">

      <%= f.label :description,
            "Descrição do defeito" %>

      <%= f.text_area :description,
            rows: 3,
            class: "form-control" %>

    </div>

  </div>
</div>
