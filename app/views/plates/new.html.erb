<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-6">

      <div class="card shadow-sm border-0">

        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">
            <i class="bi bi-truck me-2"></i>
            Nova Placa
          </h4>
        </div>

        <div class="card-body">

          <% if @plate.errors.any? %>
            <div class="alert alert-danger">
              <h6>
                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                Não foi possível salvar:
              </h6>

              <ul class="mb-0">
                <% @plate.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @plate, local: true do |f| %>

            <div class="mb-3">
              <%= f.label :placa, class: "form-label fw-semibold" %>
              <%= f.text_field :placa,
                  class: "form-control text-uppercase",
                  placeholder: "Ex: ABC1D23" %>
            </div>

            <div class="mb-3">
              <%= f.label :setor, class: "form-label fw-semibold" %>
              <%= f.select :setor,
                  [
                    ['Armazém', 'ARMAZEM'],
                    ['Rota', 'ROTA']
                  ],
                  { prompt: "Selecione o setor" },
                  class: "form-select" %>
            </div>

            <div class="mb-3">
              <%= f.label :perfil, class: "form-label fw-semibold" %>
              <%= f.select :perfil,
                  ['GLP', 'Sem Balança', 'VUC', 'TOCO', 'TRUCK', 'BITRUCK', 'VAN'],
                  { include_blank: "Selecione o perfil" },
                  class: "form-select" %>
            </div>

            <div class="mb-4">
              <%= f.label :tipo, class: "form-label fw-semibold" %>
              <%= f.select :tipo,
                  ['Empilhadeira', 'Paleteira', 'Máquina de Limpeza', 'Caminhão', 'Van'],
                  { prompt: "Selecione o tipo" },
                  class: "form-select" %>
            </div>

            <div class="d-flex justify-content-between">

              <%= link_to plates_path,
                  class: "btn btn-outline-secondary" do %>
                <i class="bi bi-arrow-left"></i>
                Voltar
              <% end %>

              <%= f.submit "Salvar",
                  class: "btn btn-success px-4" %>

            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
