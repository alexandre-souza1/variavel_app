<div
  id="<%= dom_id(item) %>"
  class="card mb-2 sortable-item">
  <div class="card-body d-flex justify-content-between align-items-center">

    <div>
      <strong><%= item.plate.placa %></strong>
      <br>
      <small class="text-muted"><%= item.plate.setor %></small>
    </div>

    <div>
      <span class="badge <%= item.status_badge_class %>">
        <%= item.status_label %>
      </span>
    </div>

    <% if item.unavailable? %>

      <div class="mt-2">
        <small class="text-danger fw-semibold">
          <%= item.reason.humanize %>
        </small>

        <% if item.observation.present? %>
          <div class="small text-muted">
            <%= item.observation %>
          </div>
        <% end %>
      </div>

    <% end %>

  </div>
</div>
