<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2>
        <i class="fas fa-truck me-2"></i>
        Acompanhamento Stress Test
      </h2>

      <p class="text-muted mb-0">
        Importação diária da movimentação das placas
      </p>
    </div>
  </div>

  <div class="card shadow-sm">

    <div class="card-header">
      Última importação
    </div>

    <div class="card-body">

      <% if @last_import.present? %>

        <p class="mb-1">
          <strong>Data:</strong>

          <%= l(@last_import.imported_at, format: :long) %>
        </p>

        <p class="mb-3">
          <strong>Usuário:</strong>

          <%= @last_import.user.name %>
        </p>

      <% else %>

        <div class="alert alert-warning mb-3">
          Nenhuma importação realizada.
        </div>

      <% end %>

      <%= form_with url: import_stress_tests_path,
                    multipart: true do |f| %>

        <div class="mb-3">

          <%= f.file_field :file,
                class: "form-control",
                accept: ".csv" %>

        </div>

        <%= f.submit "Importar CSV",
              class: "btn btn-primary" %>

      <% end %>

    </div>

  </div>

</div>
