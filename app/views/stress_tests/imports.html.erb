<div class="container-fluid mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2>
        <i class="fas fa-file-import me-2"></i>
        Histórico de Imports
      </h2>

      <p class="text-muted mb-0">
        Acompanhamento dos arquivos importados do Stress Test
      </p>
    </div>

    <%= link_to import_stress_tests_path,
          class: "btn btn-primary" do %>

      <i class="fas fa-upload me-2"></i>
      Novo Import

    <% end %>
  </div>


  <div class="card shadow-sm border-0">

    <div class="card-body">

      <div class="table-responsive">

        <table class="table table-hover align-middle">

          <thead class="table-light">

            <tr>
              <th>#</th>
              <th>Data Importação</th>
              <th>Usuário</th>
              <th>Eventos</th>
              <th>Ações</th>
            </tr>

          </thead>


          <tbody>

            <% @imports.each do |import| %>

              <tr>

                <td>
                  <%= import.id %>
                </td>


                <td>
                  <%= l(import.imported_at || import.created_at,
                        format: :short) %>
                </td>


                <td>
                  <%= import.user.name || import.user.email %>
                </td>


                <td>

                  <span class="badge bg-info">
                    <%= import.stress_test_events.size %>
                    registros
                  </span>

                </td>


                <td>

                  <%= link_to import_details_stress_test_path(import),
                        class: "btn btn-sm btn-outline-primary" do %>

                    <i class="fas fa-eye"></i>

                  <% end %>

                </td>


              </tr>

            <% end %>


            <% if @imports.empty? %>

              <tr>

                <td colspan="5"
                    class="text-center text-muted py-4">

                  Nenhum import realizado.

                </td>

              </tr>

            <% end %>


          </tbody>


        </table>

      </div>

    </div>

  </div>

</div>
