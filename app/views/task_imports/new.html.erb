<div class="container mt-4">
  <div class="card shadow-sm">
    <div class="card-body">
      <h4 class="mb-3">
        <i class="fas fa-file-import me-2"></i> Importar Tasks
      </h4>

      <%= form_with url: task_imports_path, local: true, multipart: true do %>
        <div class="mb-3">
          <label class="form-label">Arquivo (.xlsx)</label>
          <%= file_field_tag :file, accept: ".xlsx", class: "form-control" %>
        </div>

        <div class="d-flex justify-content-between">
          <%= link_to action_plans_path, class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left me-1"></i> Voltar
          <% end %>

          <%= submit_tag "Importar", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
