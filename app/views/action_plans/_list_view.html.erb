<div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
  <table class="table table-hover">
    <thead>
      <tr>
        <th>Tarefa</th>
        <th>Descrição</th>
        <th>Bucket</th>
        <th>Labels</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% buckets.each do |bucket| %>
        <% bucket.tasks.each do |task| %>
          <tr
            data-controller="task-modal"
            data-action="click->task-modal#open"
            data-task-id="<%= task.id %>"
            data-plan-id="<%= action_plan.id %>"
            style="cursor: pointer;"
          >
            <td style="max-width: 200px;"><strong class="text-truncate d-block"><%= task.title %></strong></td>
            <td class="text-truncate" style="max-width: 200px;"><%= task.description %></td>
            <td><span class="badge bg-secondary"><%= bucket.name %></span></td>
            <td>
              <% task.labels.each do |label| %>
                <span class="badge" style="background-color: <%= label.color %>;"><%= label.name %></span>
              <% end %>
            </td>
            <td>
              <button
              class="btn btn-sm btn-outline-primary"
              data-controller="task-modal"
              data-action="click->task-modal#open"
              data-task-id="<%= task.id %>"
              data-plan-id="<%= action_plan.id %>"
              >
              Editar
              </button>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
