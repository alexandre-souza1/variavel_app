<div class="row flex-nowrap overflow-auto">

<% buckets.each do |bucket| %>
    <div class="col-3">
      <div class="card bg-light mb-3">

          <div class="card-header d-flex justify-content-between align-items-center">

            <div data-controller="bucket-edit" data-bucket-id="<%= bucket.id %>" class="flex-grow-1">

                <!-- Título -->
                <span data-bucket-edit-target="title"
                    data-action="click->bucket-edit#edit"
                    style="cursor: pointer;">
                <%= bucket.name %>
                </span>

                <!-- Input oculto -->
                <input type="text"
                    value="<%= bucket.name %>"
                    data-bucket-edit-target="input"
                    data-action="blur->bucket-edit#save keydown->bucket-edit#enter"
                    class="form-control form-control-sm d-none"
                    autocomplete="off">

            </div>

            <%= link_to "❌",
                action_plan_bucket_path(action_plan, bucket),
                data: {
                turbo_method: :delete,
                turbo_confirm: "Tem certeza?"
                },
                class: "btn btn-sm"
            %>
          </div>

          <div class="card-footer" data-controller="new-task">

            <!-- BOTÃO -->
            <button
              class="btn btn-sm btn-outline-primary w-100"
              data-action="click->new-task#toggle"
              data-new-task-target="button"
            >
              + Adicionar tarefa
            </button>

            <!-- FORM (collapse animado) -->
            <div class="collapse mt-2" data-new-task-target="wrapper">
              <div class="task-card mb-2 p-2 shadow-sm">

                <%= form_with model: [action_plan, bucket, Task.new],
                  data: {action: "turbo:submit-end->new-task#afterSubmit", new_task_target: "form"} do |f| %>

                  <!-- Título -->
                  <%= f.text_field :title,
                    placeholder: "Nome da tarefa...",
                    class: "form-control mb-2",
                    data: { new_task_target: "title" },
                    required: true %>

                  <!-- DATA -->
                  <div data-controller="toggle-field" class="mb-2">
                    <button
                      type="button"
                      class="btn btn-light text-dark btn-sm w-100 align-items-start d-flex gap-1"
                      data-action="click->toggle-field#toggle"
                      data-toggle-field-target="button"
                    >
                      📅 Definir data
                    </button>

                    <div class="mt-2 d-none" data-toggle-field-target="field">
                      <%= f.date_field :due_at,
                        class: "form-control",
                        data: { action: "change->toggle-field#updateDate" } %>
                    </div>
                  </div>

                  <!-- RESPONSÁVEIS -->
                  <div data-controller="toggle-field" class="mb-2">
                    <button
                      type="button"
                      class="btn btn-light text-dark btn-sm w-100 align-items-start d-flex gap-1"
                      data-action="click->toggle-field#toggle"
                      data-toggle-field-target="button"
                    >
                      👤 Atribuir responsável
                    </button>

                    <div class="mt-2 d-none" data-toggle-field-target="field">
                      <%= f.collection_select :user_ids,
                        User.all,
                        :id,
                        :name,
                        {},
                        {
                          class: "form-select",
                          multiple: true,
                          data: {
                            controller: "tom-select-users",
                            action: "change->toggle-field#updateUsers"
                          }
                        } %>
                    </div>
                  </div>

                  <!-- Ações -->
                  <div class="d-flex justify-content-between gap-1">
                    <button class="btn btn-primary col-10">Salvar</button>
                    <button
                      type="button"
                      class="btn btn-outline-secondary col-1 align-items-center d-flex justify-content-center"
                      data-action="click->new-task#cancel"
                    >
                      <i class="bi bi-x"></i>
                    </button>
                  </div>

                <% end %>
              </div>
            </div>
          </div>

          <div
          class="card-body"
          data-controller="sortable"
          data-sortable-bucket-id-value="<%= bucket.id %>"
          data-bucket-id="<%= bucket.id %>"
          style="min-height: 300px;"
          >
          <% bucket.tasks.order(:position).each do |task| %>
            <div
              class="task-card mb-2 p-2 shadow-sm"
              data-id="<%= task.id %>"
              data-controller="task-modal"
              data-action="click->task-modal#open"
              data-task-id="<%= task.id %>"
              data-plan-id="<%= action_plan.id %>"
            >

              <!-- Labels -->
              <% if task.labels.any? %>
                <div class="task-labels mb-1">
                  <% task.labels.each do |label| %>
                    <span class="badge" style="background-color: <%= label.color %>">
                      <%= label.name %>
                    </span>
                  <% end %>
                </div>
              <% end %>

              <!-- Título -->
              <div class="task-title">
                <%= task.title %>
              </div>

              <!-- Descrição -->
              <% if task.description.present? %>
                <div class="task-desc">
                  <%= truncate(task.description, length: 80) %>
                </div>
              <% end %>

              <!-- Footer -->
              <div class="task-footer d-flex justify-content-between align-items-center mt-2">

                <!-- ESQUERDA -->
                <div class="task-meta">
                  <% if task.due_at.present? %>
                    <small class="task-date">
                      📅 <%= task.due_at.strftime("%d/%m") %>
                    </small>
                  <% end %>
                </div>

                <!-- DIREITA -->
                <div class="task-icons d-flex align-items-center gap-2">

                  <% if task.comments.any? %>
                    <small class="task-icon">💬</small>
                  <% end %>

                  <div class="avatar-group">
                    <% task.users.limit(3).each do |user| %>
                      <div class="avatar-circle-sm">
                        <%= user.name.first.upcase %>
                      </div>
                    <% end %>

                    <% if task.users.count > 3 %>
                      <div class="avatar-circle-sm extra">
                        +<%= task.users.count - 3 %>
                      </div>
                    <% end %>
                  </div>

                </div>
              </div>

            </div>
          <% end %>
          </div>
      </div>
    </div>
<% end %>


</div>
