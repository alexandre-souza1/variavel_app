<div class="modal fade" id="overdueTasksModal" tabindex="-1">

  <div class="modal-dialog modal-lg">

    <div class="modal-content">

      <div class="modal-header">

        <h5 class="modal-title text-danger">
          ⏰ Tarefas atrasadas
        </h5>

        <button type="button"
                class="btn-close"
                data-bs-dismiss="modal"></button>

      </div>


      <div class="modal-body">

        <% if overdue_tasks.any? %>


          <% overdue_tasks.each do |task| %>


            <div class="border-bottom py-2 d-flex justify-content-between align-items-start">


              <div>


                <div class="fw-bold">
                  <%= task.title %>
                </div>


                <small class="text-muted">
                  Bucket:
                  <%= task.bucket.name %>
                </small>

                <br>


                <small class="text-muted">
                  Plano:
                  <%= task.bucket.action_plan.name %>
                </small>


                <% if task.due_at %>

                  <div class="small mt-1 text-danger">
                    ⏰ Atrasada desde:
                    <%= l(task.due_at.to_date, format: :short) %>
                  </div>

                <% end %>


                <div class="mt-1">

                  <% task.users.each do |user| %>

                    <span class="badge bg-secondary text-dark me-1">
                      <%= user.name.split.first %>
                    </span>

                  <% end %>

                </div>


              </div>


              <div class="ms-3">


                <%= link_to action_plan_path(
                      task.bucket.action_plan,
                      task_id: task.id
                    ),
                    class: "btn btn-sm btn-outline-primary" do %>


                  <i class="fas fa-arrow-right me-1"></i>

                  Abrir tarefa no plano


                <% end %>


              </div>


            </div>


          <% end %>


        <% else %>


          <p class="text-muted mb-0">
            Nenhuma tarefa atrasada 🎉
          </p>


        <% end %>


      </div>


    </div>


  </div>


</div>
