<div class="container-fluid">
<div class="d-flex justify-content-between align-items-center mb-4">

  <!-- LEFT -->
  <div class="d-flex align-items-center gap-3">

    <div>
      <h3 class="mb-0">
        <i class="fas fa-file-invoice me-2"></i>
        <%= @action_plan.name %>
      </h3>

      <small class="text-muted">
        Criado em <%= l(@action_plan.created_at, format: :long) %>
      </small>
    </div>

  </div>

  <!-- RIGHT -->
  <div class="d-flex gap-2">
    <%= link_to action_plans_path, class: "btn btn-outline-secondary" do %>
      <i class="fas fa-arrow-left me-1"></i> Voltar
    <% end %>
  </div>

</div>

  <div class="mb-3">
    <%= link_to "Kanban", action_plan_path(@action_plan, view: "kanban"),
        class: "btn btn-outline-primary #{params[:view] != 'list' ? 'active' : ''}" %>

    <%= link_to "Lista", action_plan_path(@action_plan, view: "list"),
        class: "btn btn-outline-primary #{params[:view] == 'list' ? 'active' : ''}" %>
  </div>

  <div class="mb-3">
  <%= form_with model: [@action_plan, Bucket.new], local: true do |f| %>
      <div class="input-group">
      <%= f.text_field :name, placeholder: "Novo bucket...", class: "form-control" %>
      <button class="btn btn-primary">Criar</button>
      </div>
  <% end %>
  </div>

  <% if params[:view] == "list" %>
    <%= render "list_view", buckets: @buckets, action_plan: @action_plan %>
  <% else %>
    <%= render "kanban_view", buckets: @buckets, action_plan: @action_plan %>
  <% end %>
</div>
