<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3><%= @action_plan.name %></h3>
  </div>

  <div class="mb-3">
    <%= link_to "Kanban", action_plan_path(@action_plan, view: "kanban"),
        class: "btn btn-outline-primary #{params[:view] != 'list' ? 'active' : ''}" %>

    <%= link_to "Lista", action_plan_path(@action_plan, view: "list"),
        class: "btn btn-outline-primary #{params[:view] == 'list' ? 'active' : ''}" %>
  </div>

  <div class="mb-3">
  <%= form_with model: [@action_plan, Bucket.new], local: true do |f| %>
      <div class="input-group">
      <%= f.text_field :name, placeholder: "Novo bucket...", class: "form-control" %>
      <button class="btn btn-primary">Criar</button>
      </div>
  <% end %>
  </div>

  <% if params[:view] == "list" %>
    <%= render "list_view", buckets: @buckets, action_plan: @action_plan %>
  <% else %>
    <%= render "kanban_view", buckets: @buckets, action_plan: @action_plan %>
  <% end %>
</div>
