<% if action_plans.any? %>
  <div class="list-group list-group-flush">
    <% action_plans.each do |plan| %>
      <div class="list-group-item">
        <h6 class="mb-1"><%= plan.name %></h6>
        <p class="text-muted small mb-1">
          <%= plan.description&.truncate(80) %>
        </p>
        <div class="d-flex gap-2 flex-wrap">
          <%= link_to "Abrir", action_plan_path(plan), class: "btn btn-sm btn-primary" %>
          <% if plan.user == current_user or current_user.admin? %>
            <%= link_to "Editar", edit_action_plan_path(plan), class: "btn btn-sm btn-outline-secondary" %>
            <button class="btn btn-sm btn-outline-danger"
                    data-bs-toggle="modal"
                    data-bs-target="#deleteModal-<%= plan.id %>">
              Excluir
            </button>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="p-3 text-muted text-center">
    Nenhum plano criado ainda.
  </div>
<% end %>
