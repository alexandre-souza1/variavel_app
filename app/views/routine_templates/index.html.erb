<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0">
        Templates de Rotina
      </h2>

      <small class="text-muted">
        Modelos utilizados para gerar as rotinas.
      </small>
    </div>

    <%= link_to "Novo Template",
                new_routine_template_path,
                class: "btn btn-primary" %>
  </div>

  <% if @routine_templates.any? %>

    <div class="row g-3">

      <% @routine_templates.each do |template| %>

        <div class="col-md-6 col-xl-4">

          <div class="card shadow-sm h-100">

            <div class="card-body">

              <h5 class="card-title">
                <%= template.name %>
              </h5>

              <p class="text-muted mb-3">
                <%= template.description %>
              </p>

              <div class="d-flex gap-2">

                <%= link_to "Abrir",
                            template,
                            class: "btn btn-sm btn-primary" %>

                <%= link_to "Editar",
                            edit_routine_template_path(template),
                            class: "btn btn-sm btn-outline-secondary" %>

              </div>

            </div>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="text-center py-5">

      <h4>Nenhum template cadastrado</h4>

      <p class="text-muted">
        Crie seu primeiro modelo de rotina.
      </p>

    </div>

  <% end %>

</div>
