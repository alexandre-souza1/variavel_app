<div class="container py-4">

  <div class="row justify-content-center">

    <div class="col-xl-8">

      <div class="card border-0 shadow-lg">

        <div class="card-header bg-primary text-white py-3">

          <div class="d-flex justify-content-between align-items-center">

            <h3 class="mb-0 fw-bold">
              <i class="bi bi-person-gear me-2"></i>
              Editar Usuário
            </h3>

            <%= link_to admin_users_path,
                class: "btn btn-light" do %>

              <i class="bi bi-arrow-left"></i>
              Voltar

            <% end %>

          </div>

        </div>

        <div class="card-body p-5">

          <% if @user.errors.any? %>

            <div class="alert alert-danger">

              <h6 class="fw-bold">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Não foi possível salvar.
              </h6>

              <ul class="mb-0">
                <% @user.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>

            </div>

          <% end %>

          <%= form_with(model: [:admin, @user], local: true, html: { multipart: true }) do |f| %>

            <div class="mb-4">

              <%= f.label :name, "Nome", class: "form-label fw-semibold" %>

              <div class="input-group">

                <span class="input-group-text">
                  <i class="bi bi-person-fill"></i>
                </span>

                <%= f.text_field :name,
                    class: "form-control",
                    placeholder: "Nome completo" %>

              </div>

            </div>

            <div class="mb-4">

              <%= f.label :email, class: "form-label fw-semibold" %>

              <div class="input-group">

                <span class="input-group-text">
                  <i class="bi bi-envelope-fill"></i>
                </span>

                <%= f.email_field :email,
                    class: "form-control",
                    placeholder: "usuario@email.com" %>

              </div>

            </div>

            <div class="mb-4">

              <%= f.label :photo, "Foto de Perfil", class: "form-label fw-semibold" %>

              <%= f.file_field :photo, class: "form-control" %>

              <% if @user.photo.attached? %>

                <div class="mt-3 d-flex align-items-center">

                  <%= image_tag @user.photo.variant(resize_to_limit: [120,120]),
                      class: "rounded-circle border shadow-sm me-3" %>

                  <div>

                    <div class="form-check">

                      <%= f.check_box :remove_photo,
                          class: "form-check-input" %>

                      <%= f.label :remove_photo,
                          "Remover foto",
                          class: "form-check-label" %>

                    </div>

                  </div>

                </div>

              <% end %>

            </div>

            <% if current_user.admin? %>

              <div class="mb-4">

                <%= f.label :role, "Perfil", class: "form-label fw-semibold" %>

                <div class="input-group">

                  <span class="input-group-text">
                    <i class="bi bi-person-badge-fill"></i>
                  </span>

                  <%= f.select :role,
                      [["Admin","admin"],["Supervisor","supervisor"],["Usuário","user"],["Mecânico","mechanical"]],
                      {},
                      class: "form-select" %>

                </div>

              </div>

              <div class="mb-4">

                <%= f.label :sector, "Setor", class: "form-label fw-semibold" %>

                <div class="input-group">

                  <span class="input-group-text">
                    <i class="bi bi-building"></i>
                  </span>

                  <%= f.select :sector,
                      User::USER_SECTORS.map { |label, value| [label, value] },
                      { include_blank: "Selecione um setor" },
                      class: "form-select" %>

                </div>

              </div>

            <% end %>

            <hr class="my-5">

            <h5 class="fw-bold mb-4">

              <i class="bi bi-key-fill me-2"></i>

              Alterar Senha

            </h5>

            <div class="mb-4">

              <%= f.label :password, "Nova senha", class: "form-label fw-semibold" %>

              <div class="input-group">

                <span class="input-group-text">
                  <i class="bi bi-lock-fill"></i>
                </span>

                <%= f.password_field :password,
                    class: "form-control" %>

              </div>

            </div>

            <div class="mb-5">

              <%= f.label :password_confirmation,
                  "Confirmar senha",
                  class: "form-label fw-semibold" %>

              <div class="input-group">

                <span class="input-group-text">
                  <i class="bi bi-shield-lock-fill"></i>
                </span>

                <%= f.password_field :password_confirmation,
                    class: "form-control" %>

              </div>

            </div>

            <div class="d-flex justify-content-end gap-2">

              <%= link_to admin_users_path,
                  class: "btn btn-outline-secondary" do %>

                <i class="bi bi-x-circle"></i>
                Cancelar

              <% end %>

              <%= f.submit "Salvar Alterações",
                  class: "btn btn-primary px-4" %>

            </div>

          <% end %>

        </div>

      </div>

    </div>

  </div>

</div>
