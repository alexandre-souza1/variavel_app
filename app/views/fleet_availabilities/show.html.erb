<% available_items = @items.select(&:available?) %>
<% deposit_items = @items.select(&:exchange?) %>
<% unavailable_items = @items.select(&:unavailable?) %>
<% special_route_items = @items.select(&:special_route?).group_by(&:special_route) %>
<% availability_slots = [@fleet_availability.agreed_quantity, 0].max %>
<% empty_slots = [availability_slots - available_items.size, 0].max %>

<div class="container-fluid py-4 fleet-availability-page"
     data-controller="fleet-availability"
     data-availability-id="<%= @fleet_availability.id %>">

  <div class="fleet-availability-header mb-4">

    <div>
      <h2 class="fw-bold mb-1">
        Disponibilidade da Frota
      </h2>

      <div class="text-muted">
        <i class="bi bi-calendar-event"></i>
        <%= l(@fleet_availability.date) %>
      </div>
    </div>

    <div class="fleet-coverage-panel">

      <span class="text-muted">
        Cobertura
      </span>

      <strong data-coverage-percentage>
        <%= @fleet_availability.coverage_percentage %>%
      </strong>

      <small data-coverage-ratio>
        <%= @fleet_availability.available_count %> /
        <%= @fleet_availability.agreed_quantity %> linhas
      </small>

    </div>

  </div>

  <div class="fleet-limit-alert d-none mb-3"
       data-limit-alert
       role="alert">
    <i class="bi bi-exclamation-triangle-fill"></i>
    <span data-limit-alert-message>
      Não é possível adicionar outra placa: a disponibilidade já atingiu o limite pactuado.
    </span>
  </div>

  <% if @fleet_availability.active_special_routes.any? %>
    <section class="card shadow-sm fleet-board-card fleet-special-routes mb-3">

      <div class="card-header fleet-board-card__header">
        <div>
          <span class="fleet-board-card__title">
            Rotas especiais dimensionadas
          </span>

          <small>
            Roteirize apenas se a rota veio dimensionada na quinzena
          </small>
        </div>
      </div>

      <div class="card-body fleet-special-routes__body">
        <% @fleet_availability.active_special_routes.each do |route_key, route_quantity| %>
          <% route_items = special_route_items.fetch(route_key, []) %>
          <% route_empty_slots = [route_quantity - route_items.size, 0].max %>
          <% route_label = FleetAvailability::SPECIAL_ROUTES[route_key] %>

          <div class="fleet-special-route-card <%= "fleet-special-route-card--filled" if route_items.any? %>"
               data-special-route-card="<%= route_key %>">
            <div class="fleet-special-route-card__header">
              <strong><%= route_label %></strong>

              <% if route_key == "van" %>
                <small>Somente placa VAN</small>
              <% else %>
                <small>Qualquer carro da rota</small>
              <% end %>

              <span class="fleet-count-badge"
                    data-special-route-count="<%= route_key %>">
                <%= route_items.size %> / <%= route_quantity %>
              </span>
            </div>

            <div class="fleet-special-route-list sortable-list"
                 id="special-route-<%= route_key %>-list"
                 data-special-route="<%= route_key %>"
                 data-max-items="<%= route_quantity %>">
              <% route_items.each do |route_item| %>
                <%= render "fleet_availability_items/item",
                           item: route_item,
                           variant: :special_route %>
              <% end %>

              <% route_empty_slots.times do %>
                <div class="fleet-special-route-placeholder">
                  Arraste uma placa
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

    </section>
  <% end %>

  <div class="row g-3 fleet-board">

    <div class="col-xl-6">

      <section class="card shadow-sm h-100 fleet-board-card fleet-board-card--main">

        <div class="card-header fleet-board-card__header">

          <div>
            <span class="fleet-board-card__title">
              Disponibilidade
            </span>

            <small>
              Placas que compõem a operação do dia
            </small>
          </div>

          <span class="fleet-count-badge fleet-count-badge--success"
                data-count="available">
            <%= available_items.size %> / <%= availability_slots %>
          </span>

        </div>

        <div class="card-body fleet-list fleet-list--availability sortable-list"
             id="available-list"
             data-max-items="<%= availability_slots %>"
             style="--fleet-visible-rows: <%= [availability_slots, 1].max %>;">

          <% available_items.each do |item| %>
            <%= render "fleet_availability_items/item",
                       item: item,
                       variant: :availability %>
          <% end %>

          <% empty_slots.times do |index| %>
            <div class="fleet-empty-slot">
              <span>
                Linha <%= available_items.size + index + 1 %>
              </span>

              <small>
                Arraste uma placa do depósito
              </small>
            </div>
          <% end %>

        </div>

      </section>

    </div>

    <div class="col-xl-3 col-lg-6">

      <section class="card shadow-sm h-100 fleet-board-card">

        <div class="card-header fleet-board-card__header">

          <div>
            <span class="fleet-board-card__title">
              Depósito de placas
            </span>

            <small>
              Ativas e disponíveis para montar a escala
            </small>
          </div>

          <span class="fleet-count-badge"
                data-count="exchange">
            <%= deposit_items.size %>
          </span>

        </div>

        <div class="card-body fleet-list fleet-list--deposit sortable-list"
             id="exchange-list">

          <% deposit_items.each do |item| %>
            <%= render "fleet_availability_items/item",
                       item: item,
                       variant: :deposit %>
          <% end %>

        </div>

      </section>

    </div>

    <div class="col-xl-3 col-lg-6">

      <section class="card shadow-sm h-100 fleet-board-card fleet-board-card--danger">

        <div class="card-header fleet-board-card__header">

          <div>
            <span class="fleet-board-card__title">
              Indisponíveis
            </span>

            <small>
              Placas com defeito ou bloqueio
            </small>
          </div>

          <span class="fleet-count-badge fleet-count-badge--danger"
                data-count="unavailable">
            <%= unavailable_items.size %>
          </span>

        </div>

        <div class="card-body fleet-list sortable-list"
             id="unavailable-list">

          <% unavailable_items.each do |item| %>
            <%= render "fleet_availability_items/item",
                       item: item,
                       variant: :unavailable %>
          <% end %>

        </div>

      </section>

    </div>

  </div>

  <div class="mt-4">

    <%= link_to fleet_availabilities_path,
                class: "btn btn-outline-secondary" do %>

      <i class="bi bi-arrow-left"></i>
      Voltar

    <% end %>

  </div>

</div>


<div class="modal fade"
     id="unavailableModal"
     tabindex="-1">

  <div class="modal-dialog">

    <div class="modal-content">

      <div class="modal-header">

        <h5 class="modal-title">
          Defeito da placa
        </h5>

        <button type="button"
                class="btn-close"
                data-bs-dismiss="modal">
        </button>

      </div>

      <div class="modal-body">

        <div class="mb-3">

          <label class="form-label">
            Defeito
          </label>

          <select id="unavailableReason"
                  class="form-select">

            <option value="maintenance">
              Manutenção
            </option>

            <option value="breakdown">
              Quebra
            </option>

            <option value="accident">
              Acidente
            </option>

            <option value="document">
              Documentação
            </option>

            <option value="other">
              Outro
            </option>

          </select>

        </div>

        <div>

          <label class="form-label">
            Observação
          </label>

          <textarea id="unavailableObservation"
                    rows="4"
                    class="form-control"></textarea>

        </div>

      </div>

      <div class="modal-footer">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">

          Cancelar

        </button>

        <button type="button"
                id="confirmUnavailable"
                class="btn btn-danger">

          Confirmar

        </button>

      </div>

    </div>

  </div>

</div>
