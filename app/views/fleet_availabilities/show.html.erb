<% available_items = @items.select(&:available?) %>
<% deposit_items = @items.select(&:exchange?) %>
<% unavailable_items = @items.select(&:unavailable?) %>
<% special_route_items = @items.select(&:special_route?).group_by(&:special_route) %>
<% availability_slots = [@fleet_availability.agreed_quantity, 0].max %>
<% empty_slots = [availability_slots - available_items.size, 0].max %>
<% maintenance_count = unavailable_items.count { |item| item.reason == "maintenance" } %>
<% maintenance_percentage = @items.any? ? ((maintenance_count.to_f / @items.size) * 100).round : 0 %>
<% used_items = available_items + @items.select(&:special_route?) %>
<% used_profile_counts = used_items.each_with_object(Hash.new(0)) { |item, counts| counts[item.plate.perfil.presence || "Sem perfil"] += 1 } %>
<% creator_name = @fleet_availability.user.name.presence || @fleet_availability.user.email %>

<div class="container-fluid py-4 fleet-availability-page <%= "fleet-availability-page--readonly" unless @editable %>"
     data-controller="fleet-availability"
     data-availability-id="<%= @fleet_availability.id %>"
     data-editable="<%= @editable %>">

  <div class="fleet-availability-header mb-4">

    <div>
      <h2 class="fw-bold mb-1">
        Disponibilidade da Frota
      </h2>

      <div class="text-muted">
        <i class="bi bi-calendar-event"></i>
        <%= l(@fleet_availability.date) %>
      </div>

      <div class="text-muted small mt-1">
        Iniciada por <%= creator_name %>
      </div>
    </div>

    <div class="d-flex align-items-center gap-3 flex-wrap justify-content-end">
      <% if @locking_enabled %>
        <% if @fleet_availability.locked? %>
          <span class="badge text-bg-secondary">
            <i class="bi bi-lock-fill"></i>
            Travada
          </span>
        <% else %>
          <span class="badge text-bg-light border text-muted">
            <i class="bi bi-unlock"></i>
            Aberta
          </span>
        <% end %>
      <% end %>

      <% if @editable && @locking_enabled %>
        <%= button_to lock_fleet_availability_path(@fleet_availability),
                      method: :patch,
                      class: "btn btn-outline-secondary",
                      form: {
                        data: {
                          turbo_confirm: "Depois de travar, a disponibilidade ficará somente leitura. Confirma?"
                        }
                      } do %>
          <i class="bi bi-lock"></i>
          Travar
        <% end %>
      <% elsif @locking_enabled && @fleet_availability.locked? && current_user.admin? %>
        <%= button_to unlock_fleet_availability_path(@fleet_availability),
                      method: :patch,
                      class: "btn btn-outline-secondary",
                      form: {
                        data: {
                          turbo_confirm: "Destravar esta disponibilidade para edição do criador?"
                        }
                      } do %>
          <i class="bi bi-unlock"></i>
          Destravar
        <% end %>
      <% end %>

      <%= link_to fleet_availability_path(@fleet_availability, format: :pdf),
                  class: "btn btn-outline-danger",
                  target: "_blank",
                  rel: "noopener" do %>
        <i class="bi bi-file-earmark-pdf"></i>
        PDF
      <% end %>

      <%= link_to fleet_availabilities_path,
                  class: "btn btn-outline-secondary" do %>

        <i class="bi bi-arrow-left"></i>
        Voltar

      <% end %>

      <div class="fleet-kpi-panel">

        <span class="text-muted">
          Cobertura
        </span>

        <strong data-coverage-percentage>
          <%= @fleet_availability.coverage_percentage %>%
        </strong>

        <small data-coverage-ratio>
          <%= @fleet_availability.available_count %> /
          <%= @fleet_availability.agreed_quantity %> linhas
        </small>

      </div>

      <div class="fleet-kpi-panel fleet-kpi-panel--danger">
        <span class="text-muted">
          Manutenção
        </span>

        <strong data-maintenance-percentage>
          <%= maintenance_percentage %>%
        </strong>

        <small data-maintenance-ratio>
          <%= maintenance_count %> /
          <%= @items.size %> veículos
        </small>
      </div>

      <div class="fleet-profile-panel">
        <span class="text-muted">
          Em uso por perfil
        </span>

        <div data-used-profile-counts>
          <% %w[VUC TOCO TRUCK BITRUCK].each do |profile| %>
            <small data-used-profile="<%= profile %>">
              <strong><%= profile %></strong>
              <span data-used-profile-count>
                <%= used_profile_counts[profile] %>
              </span>
            </small>
          <% end %>
        </div>
      </div>

    </div>

  </div>

  <div class="fleet-limit-alert d-none mb-3"
       data-limit-alert
       role="alert">
    <i class="bi bi-exclamation-triangle-fill"></i>
    <span data-limit-alert-message>
      Não é possível adicionar outra placa: a disponibilidade já atingiu o limite pactuado.
    </span>
  </div>

  <% unless @editable %>
    <div class="fleet-readonly-alert mb-3" role="status">
      <i class="bi bi-lock-fill"></i>
      <span>
        <% if @fleet_availability.locked? %>
          Esta disponibilidade está travada<%= " por #{@fleet_availability.locked_by.name.presence || @fleet_availability.locked_by.email}" if @fleet_availability.locked_by.present? %>.
          Solicite ao admin para destravar.
        <% else %>
          Esta disponibilidade está em somente leitura para seu usuário.
          Apenas quem iniciou (<%= creator_name %>) pode editar.
        <% end %>
      </span>
    </div>
  <% end %>

  <% if @fleet_availability.active_special_routes.any? %>
    <section class="card shadow-sm fleet-board-card fleet-special-routes mb-3">

      <div class="card-header fleet-board-card__header">
        <div>
          <span class="fleet-board-card__title">
            Rotas especiais dimensionadas
          </span>

          <small>
            Roteirize apenas se a rota veio dimensionada na quinzena
          </small>
        </div>
      </div>

      <div class="card-body fleet-special-routes__body">
        <% @fleet_availability.active_special_routes.each do |route_key, route_quantity| %>
          <% route_items = special_route_items.fetch(route_key, []) %>
          <% route_empty_slots = [route_quantity - route_items.size, 0].max %>
          <% route_label = FleetAvailability::SPECIAL_ROUTES[route_key] %>

          <div class="fleet-special-route-card <%= "fleet-special-route-card--filled" if route_items.any? %>"
               data-special-route-card="<%= route_key %>">
            <div class="fleet-special-route-card__header">
              <strong><%= route_label %></strong>

              <% if route_key == "van" %>
                <small>Somente placa VAN</small>
              <% else %>
                <small>Qualquer carro da rota</small>
              <% end %>

              <span class="fleet-count-badge"
                    data-special-route-count="<%= route_key %>">
                <%= route_items.size %> / <%= route_quantity %>
              </span>
            </div>

            <div class="fleet-special-route-list sortable-list"
                 id="special-route-<%= route_key %>-list"
                 data-special-route="<%= route_key %>"
                 data-max-items="<%= route_quantity %>">
              <% route_items.each do |route_item| %>
            <%= render "fleet_availability_items/item",
                       item: route_item,
                       variant: :special_route,
                       editable: @editable %>
              <% end %>

              <% route_empty_slots.times do %>
                <div class="fleet-special-route-placeholder">
                  Arraste uma placa
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

    </section>
  <% end %>

  <div class="row g-3 fleet-board">

    <div class="col-xl-8">
      <section class="card shadow-sm h-100 fleet-board-card fleet-board-card--main">
        <div class="card-header fleet-board-card__header">
          <div>
            <span class="fleet-board-card__title">Disponibilidade</span>
            <small>Placas que compõem a operação do dia</small>
          </div>
          <span class="fleet-count-badge fleet-count-badge--success" data-count="available">
            <%= available_items.size %> / <%= availability_slots %>
          </span>
        </div>
        <div class="card-body fleet-list fleet-list--availability sortable-list"
            id="available-list"
            data-max-items="<%= availability_slots %>"
            data-standard-plates="<%= @standard_plate_by_position.transform_values { |standard_plate| standard_plate.plate.placa }.to_json %>"
            style="--fleet-visible-rows: <%= [availability_slots, 1].max %>;">
          <% available_items.each do |item| %>
            <%= render "fleet_availability_items/item",
                       item: item,
                       variant: :availability,
                       standard_plate: @standard_plate_by_position[item.position.to_i]&.plate,
                       editable: @editable %>
          <% end %>
          <% empty_slots.times do |index| %>
            <% position = available_items.size + index %>
            <% standard_plate = @standard_plate_by_position[position]&.plate %>
            <div class="fleet-empty-slot">
              <span>Linha <%= position + 1 %></span>
              <small>
                <% if standard_plate.present? %>
                  Placa padrão da posição:
                  <%= standard_plate.placa %>
                <% else %>
                  Placa padrão da posição não definida
                <% end %>
              </small>
            </div>
          <% end %>
        </div>
      </section>
    </div>

    <div class="col-xl-4 d-flex flex-column gap-3">
      <section class="card shadow-sm fleet-board-card fleet-board-card--danger">
        <div class="card-header fleet-board-card__header">
          <div>
            <span class="fleet-board-card__title">Indisponíveis</span>
            <small>Placas com defeito ou bloqueio</small>
          </div>
          <span class="fleet-count-badge fleet-count-badge--danger" data-count="unavailable">
            <%= unavailable_items.size %>
          </span>
        </div>
        <div class="card-body fleet-list fleet-list--unavailable-grid sortable-list" id="unavailable-list">
          <% unavailable_items.each do |item| %>
            <%= render "fleet_availability_items/item",
                       item: item,
                       variant: :unavailable,
                       editable: @editable %>
          <% end %>
        </div>
      </section>
      <section class="card shadow-sm fleet-board-card flex-grow-1">
        <div class="card-header fleet-board-card__header">
          <div>
            <span class="fleet-board-card__title">Depósito de placas</span>
            <small>Ativas e disponíveis para montar a escala</small>
          </div>
          <span class="fleet-count-badge" data-count="exchange">
            <%= deposit_items.size %>
          </span>
        </div>
        <div class="card-body fleet-list fleet-list--deposit sortable-list" id="exchange-list">
          <% deposit_items.each do |item| %>
            <%= render "fleet_availability_items/item",
                       item: item,
                       variant: :deposit,
                       editable: @editable %>
          <% end %>
        </div>
      </section>
    </div>

  </div>

  <div class="mt-4 d-flex justify-content-between">

    <%= link_to fleet_availabilities_path,
                class: "btn btn-outline-secondary" do %>

      <i class="bi bi-arrow-left"></i>
      Voltar

    <% end %>

    <% if current_user.admin? %>
      <%= button_to @fleet_availability,
                    method: :delete,
                    class: "btn btn-outline-danger",
                    form: {
                      data: {
                        turbo_confirm: "Tem certeza que deseja apagar esta disponibilidade?"
                      }
                    } do %>
        <i class="bi bi-trash"></i>
        Apagar
      <% end %>
    <% end %>

  </div>

</div>

<div class="modal fade"
     id="plateObservationModal"
     tabindex="-1">

  <div class="modal-dialog">

    <div class="modal-content">

      <div class="modal-header">

        <h5 class="modal-title">
          Observação da placa
        </h5>

        <button type="button"
                class="btn-close"
                data-bs-dismiss="modal">
        </button>

      </div>

      <div class="modal-body">

        <textarea id="plateObservationText"
                  rows="4"
                  class="form-control"
                  placeholder="Digite uma observação para esta placa"></textarea>

      </div>

      <div class="modal-footer">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
          Cancelar
        </button>

        <button type="button"
                id="confirmPlateObservation"
                class="btn btn-primary">
          Salvar
        </button>

      </div>

    </div>

  </div>

</div>


<% if @editable %>
<div class="modal fade"
     id="unavailableModal"
     tabindex="-1">

  <div class="modal-dialog">

    <div class="modal-content">

      <div class="modal-header">

        <h5 class="modal-title">
          Defeito da placa
        </h5>

        <button type="button"
                class="btn-close"
                data-bs-dismiss="modal">
        </button>

      </div>

      <div class="modal-body">

        <div class="mb-3">

          <label class="form-label">
            Defeito
          </label>

          <select id="unavailableReason"
                  class="form-select">

            <option value="maintenance">
              Manutenção
            </option>

            <option value="breakdown">
              Quebra
            </option>

            <option value="accident">
              Acidente
            </option>

            <option value="document">
              Documentação
            </option>

            <option value="other">
              Outro
            </option>

          </select>

        </div>

        <div>

          <label class="form-label">
            Observação
          </label>

          <textarea id="unavailableObservation"
                    rows="4"
                    class="form-control"></textarea>

        </div>

      </div>

      <div class="modal-footer">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">

          Cancelar

        </button>

        <button type="button"
                id="confirmUnavailable"
                class="btn btn-danger">

          Confirmar

        </button>

      </div>

    </div>

  </div>

</div>

<% end %>
