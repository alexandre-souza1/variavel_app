<%= form_with model: @fleet_availability,
              class: "card shadow-sm border-0" do |f| %>

  <div class="card-header bg-primary text-white">
    <h5 class="mb-0">
      Disponibilidade da Frota
    </h5>
  </div>

  <div class="card-body">

    <% if @fleet_availability.errors.any? %>

      <div class="alert alert-danger">

        <h6 class="mb-2">
          Não foi possível salvar:
        </h6>

        <ul class="mb-0">

          <% @fleet_availability.errors.full_messages.each do |message| %>

            <li><%= message %></li>

          <% end %>

        </ul>

      </div>

    <% end %>

    <div class="row">
      <div class="col-md-12 mb-3">

        <%= f.label :date,
                    "Data",
                    class: "form-label" %>

        <%= f.date_field :date,
                         class: "form-control",
                         onchange: "window.location.href='#{new_fleet_availability_path}?date=' + this.value",
                         required: true %>

      </div>
    </div>

    <div class="form-check mt-3">
      <%= check_box_tag "fleet_availability[copy_previous_day]",
                        "1",
                        false,
                        id: "fleet_availability_copy_previous_day",
                        class: "form-check-input" %>

      <%= label_tag "fleet_availability_copy_previous_day",
                    "Copiar montagem do dia anterior",
                    class: "form-check-label" %>
    </div>

  </div>

  <div class="card-footer d-flex justify-content-between">

    <%= link_to fleet_availabilities_path,
                class: "btn btn-outline-secondary" do %>

      <i class="bi bi-arrow-left"></i>
      Voltar

    <% end %>

    <%= f.submit "Salvar",
                 class: "btn btn-primary",
                 disabled: @dimensioning_period.blank? %>

  </div>

<% end %>
