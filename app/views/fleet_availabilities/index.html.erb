<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">

    <div>

      <h2 class="fw-bold mb-1">
        Disponibilidade da Frota
      </h2>

      <p class="text-muted mb-0">
        Histórico das disponibilidades registradas.
      </p>

    </div>

    <div class="d-flex gap-2">
      <%= link_to fleet_dimensionings_path,
                  class: "btn btn-outline-primary" do %>
        <i class="bi bi-calendar-range"></i>
        Dimensionamentos
      <% end %>

      <%= link_to new_fleet_availability_path,
                  class: "btn btn-primary" do %>
        <i class="bi bi-plus-circle"></i>
        Nova Disponibilidade
      <% end %>

    </div>

  </div>

  <div class="row g-3 mb-4">

    <div class="col-md-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <span class="text-muted small">Dias registrados</span>
          <strong class="d-block fs-3">
            <%= @fleet_dashboard[:total_days] %>
          </strong>
          <small class="text-muted">
            <%= @fleet_dashboard[:open_count] %> abertas /
            <%= @fleet_dashboard[:locked_count] %> travadas
          </small>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <span class="text-muted small">Cobertura média</span>
          <strong class="d-block fs-3">
            <%= @fleet_dashboard[:average_coverage] %>%
          </strong>
          <small class="text-muted">
            Média das disponibilidades criadas
          </small>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">Resumo rápido</span>
            <i class="bi bi-bar-chart text-muted"></i>
          </div>

          <div class="row g-2">
            <div class="col-4">
              <div class="border rounded p-2 h-100">
                <small class="text-muted d-block">Mais saiu</small>
                <% first_used = @fleet_dashboard[:most_used].first %>
                <strong><%= first_used&.first || "-" %></strong>
              </div>
            </div>
            <div class="col-4">
              <div class="border rounded p-2 h-100">
                <small class="text-muted d-block">Menos saiu</small>
                <% first_idle = @fleet_dashboard[:least_used].first %>
                <strong><%= first_idle&.first || "-" %></strong>
              </div>
            </div>
            <div class="col-4">
              <div class="border rounded p-2 h-100">
                <small class="text-muted d-block">Mais manutenção</small>
                <% first_maintenance = @fleet_dashboard[:maintenance].first %>
                <strong><%= first_maintenance&.first || "-" %></strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <div class="row g-3 mb-4">

    <div class="col-lg-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white">
          <strong>Placas que mais saíram</strong>
        </div>
        <div class="card-body">
          <% if @fleet_dashboard[:most_used_chart].any? %>
            <%= bar_chart @fleet_dashboard[:most_used_chart],
                          height: "260px",
                          colors: ["#198754"],
                          library: {
                            plugins: {
                              legend: {
                                display: false
                              }
                            }
                          } %>
          <% else %>
            <div class="text-muted">
              Sem dados de saída ainda.
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white">
          <strong>Placas que menos saíram</strong>
        </div>
        <div class="card-body">
          <% if @fleet_dashboard[:least_used_chart].any? %>
            <%= bar_chart @fleet_dashboard[:least_used_chart],
                          height: "260px",
                          colors: ["#6c757d"],
                          library: {
                            plugins: {
                              legend: {
                                display: false
                              }
                            }
                          } %>
          <% else %>
            <div class="text-muted">
              Sem placas cadastradas para comparar.
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white">
          <strong>Mais tempo em manutenção</strong>
        </div>
        <div class="card-body">
          <% if @fleet_dashboard[:maintenance_chart].any? %>
            <%= bar_chart @fleet_dashboard[:maintenance_chart],
                          height: "260px",
                          colors: ["#dc3545"],
                          library: {
                            plugins: {
                              legend: {
                                display: false
                              }
                            }
                          } %>
          <% else %>
            <div class="text-muted">
              Nenhuma manutenção registrada.
            </div>
          <% end %>
        </div>
      </div>
    </div>

  </div>

  <div class="card shadow-sm border-0">

    <div class="card-body p-0">

      <% if @fleet_availabilities.any? %>

        <div class="table-responsive">

          <table class="table table-hover align-middle mb-0">

            <thead class="table-light">

              <tr>

                <th>Data</th>

                <th>Iniciada por</th>

                <th class="text-center">Status</th>

                <th class="text-center">Dimensionamento</th>

                <th class="text-center">Disponibilizados</th>

                <th class="text-center">Disponíveis p/ Troca</th>

                <th class="text-center">Indisponíveis</th>

                <th class="text-center">Cobertura</th>

                <th class="text-end"></th>

              </tr>

            </thead>

            <tbody>

              <% @fleet_availabilities.each do |availability| %>

                <tr>

                  <td>
                    <%= l(availability.date) %>
                  </td>

                  <td class="text-muted">
                    <%= availability.user.name.presence || availability.user.email %>
                  </td>

                  <td class="text-center">
                    <% if availability.locked? %>
                      <span class="badge text-bg-secondary">Travada</span>
                    <% else %>
                      <span class="badge text-bg-light border text-muted">Aberta</span>
                    <% end %>
                  </td>

                  <td class="text-center">
                    <%= availability.agreed_quantity %>
                  </td>

                  <td class="text-center">
                    <span class="badge bg-success">
                      <%= availability.available_count %>
                    </span>
                  </td>

                  <td class="text-center">
                    <span class="badge bg-warning text-dark">
                      <%= availability.exchange_count %>
                    </span>
                  </td>

                  <td class="text-center">
                    <span class="badge bg-danger">
                      <%= availability.unavailable_count %>
                    </span>
                  </td>

                  <td class="text-center">

                    <% percentage = availability.coverage_percentage %>

                    <div class="progress"
                         style="height: 20px;">

                      <div class="progress-bar
                        <%= percentage >= 100 ? "bg-success" : percentage >= 80 ? "bg-warning" : "bg-danger" %>"
                           role="progressbar"
                           style="width: <%= [percentage, 100].min %>%">

                        <%= percentage %>%

                      </div>

                    </div>

                  </td>

                  <td class="text-end">

                    <div class="d-flex justify-content-end gap-2">
                      <%= link_to availability,
                                  class: "btn btn-sm btn-outline-primary" do %>

                        <i class="bi bi-eye"></i>
                        Abrir

                      <% end %>

                      <% if current_user.admin? %>
                        <%= button_to availability,
                                      method: :delete,
                                      class: "btn btn-sm btn-outline-danger",
                                      form: {
                                        data: {
                                          turbo_confirm: "Tem certeza que deseja apagar esta disponibilidade?"
                                        }
                                      } do %>
                          <i class="bi bi-trash"></i>
                          Apagar
                        <% end %>
                      <% end %>
                    </div>

                  </td>

                </tr>

              <% end %>

            </tbody>

          </table>

        </div>

      <% else %>

        <div class="text-center py-5">

          <i class="bi bi-truck display-4 text-muted"></i>

          <h5 class="mt-3">
            Nenhuma disponibilidade cadastrada
          </h5>

          <p class="text-muted">
            Clique em <strong>Nova Disponibilidade</strong> para criar o primeiro registro.
          </p>

          <%= link_to new_fleet_availability_path,
                      class: "btn btn-primary" do %>

            <i class="bi bi-plus-circle"></i>
            Nova Disponibilidade

          <% end %>

        </div>

      <% end %>

    </div>

  </div>

</div>
