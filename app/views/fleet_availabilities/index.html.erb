<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">

    <div>

      <h2 class="fw-bold mb-1">
        Disponibilidade da Frota
      </h2>

      <p class="text-muted mb-0">
        Histórico das disponibilidades registradas.
      </p>

    </div>

    <div class="d-flex gap-2">
      <%= link_to fleet_dimensionings_path,
                  class: "btn btn-outline-primary" do %>
        <i class="bi bi-calendar-range"></i>
        Dimensionamentos
      <% end %>

      <%= link_to new_fleet_availability_path,
                  class: "btn btn-primary" do %>
        <i class="bi bi-plus-circle"></i>
        Nova Disponibilidade
      <% end %>

    </div>

  </div>

  <div class="row g-3 mb-4">

    <div class="col-md-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <span class="text-muted small">Dias registrados</span>
          <strong class="d-block fs-3">
            <%= @fleet_summary[:total_days] %>
          </strong>
          <small class="text-muted">
            Histórico de disponibilidades
          </small>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <span class="text-muted small">Cobertura média</span>
          <strong class="d-block fs-3">
            <%= @fleet_summary[:average_coverage] %>%
          </strong>
          <small class="text-muted">
            Disponíveis sobre dimensionamento
          </small>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <span class="text-muted small">Disponibilidades abertas</span>
          <strong class="d-block fs-3">
            <%= @fleet_summary[:open_count] %>
          </strong>
          <small class="text-muted">
            Ainda editáveis pelo criador
          </small>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <span class="text-muted small">Disponibilidades travadas</span>
          <strong class="d-block fs-3">
            <%= @fleet_summary[:locked_count] %>
          </strong>
          <small class="text-muted">
            Somente leitura
          </small>
        </div>
      </div>
    </div>

  </div>

  <div class="card shadow-sm border-0">

    <div class="card-body p-0">

      <% if @fleet_availabilities.any? %>

        <div class="table-responsive">

          <table class="table table-hover align-middle mb-0">

            <thead class="table-light">

              <tr>

                <th>Data</th>

                <th>Iniciada por</th>

                <th class="text-center">Status</th>

                <th class="text-center">Dimensionamento</th>

                <th class="text-center">Disponibilizados</th>

                <th class="text-center">Disponíveis p/ Troca</th>

                <th class="text-center">Indisponíveis</th>

                <th class="text-center">Cobertura</th>

                <th class="text-end"></th>

              </tr>

            </thead>

            <tbody>

              <% @fleet_availabilities.each do |availability| %>

                <tr>

                  <td>
                    <%= l(availability.date) %>
                  </td>

                  <td class="text-muted">
                    <%= availability.user.name.presence || availability.user.email %>
                  </td>

                  <td class="text-center">
                    <% if availability.locked? %>
                      <span class="badge text-bg-secondary">Travada</span>
                    <% else %>
                      <span class="badge text-bg-light border text-muted">Aberta</span>
                    <% end %>
                  </td>

                  <td class="text-center">
                    <%= availability.agreed_quantity %>
                  </td>

                  <td class="text-center">
                    <span class="badge bg-success">
                      <%= availability.available_count %>
                    </span>
                  </td>

                  <td class="text-center">
                    <span class="badge bg-warning text-dark">
                      <%= availability.exchange_count %>
                    </span>
                  </td>

                  <td class="text-center">
                    <span class="badge bg-danger">
                      <%= availability.unavailable_count %>
                    </span>
                  </td>

                  <td class="text-center">

                    <% percentage = availability.coverage_percentage %>

                    <div class="progress"
                         style="height: 20px;">

                      <div class="progress-bar
                        <%= percentage >= 100 ? "bg-success" : percentage >= 80 ? "bg-warning" : "bg-danger" %>"
                           role="progressbar"
                           style="width: <%= [percentage, 100].min %>%">

                        <%= percentage %>%

                      </div>

                    </div>

                  </td>

                  <td class="text-end">

                    <div class="d-flex justify-content-end gap-2">
                      <%= link_to availability,
                                  class: "btn btn-sm btn-outline-primary" do %>

                        <i class="bi bi-eye"></i>
                        Abrir

                      <% end %>

                      <% if current_user.admin? %>
                        <%= button_to availability,
                                      method: :delete,
                                      class: "btn btn-sm btn-outline-danger",
                                      form: {
                                        data: {
                                          turbo_confirm: "Tem certeza que deseja apagar esta disponibilidade?"
                                        }
                                      } do %>
                          <i class="bi bi-trash"></i>
                          Apagar
                        <% end %>
                      <% end %>
                    </div>

                  </td>

                </tr>

              <% end %>

            </tbody>

          </table>

        </div>

      <% else %>

        <div class="text-center py-5">

          <i class="bi bi-truck display-4 text-muted"></i>

          <h5 class="mt-3">
            Nenhuma disponibilidade cadastrada
          </h5>

          <p class="text-muted">
            Clique em <strong>Nova Disponibilidade</strong> para criar o primeiro registro.
          </p>

          <%= link_to new_fleet_availability_path,
                      class: "btn btn-primary" do %>

            <i class="bi bi-plus-circle"></i>
            Nova Disponibilidade

          <% end %>

        </div>

      <% end %>

    </div>

  </div>

</div>
