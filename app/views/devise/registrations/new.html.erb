<div class="bg-sessions min-vh-100 d-flex align-items-center">

  <div class="container">
    <div class="row justify-content-center">

      <div class="col-12 col-md-8 col-lg-5">

        <div class="card border-0 shadow-lg">

          <div class="card-body p-5">

            <div class="text-center mb-4">
              <i class="bi bi-person-plus-fill text-success display-4"></i>

              <h2 class="fw-bold mt-3 mb-1">
                Criar Conta
              </h2>

              <p class="text-muted mb-0">
                Preencha os dados abaixo para cadastrar um novo usuário.
              </p>
            </div>

            <%= render "devise/shared/error_messages", resource: resource %>

            <%= form_for(resource,
                  as: resource_name,
                  url: registration_path(resource_name)) do |f| %>

              <div class="mb-3">

                <%= f.label :email, class: "form-label fw-semibold" %>

                <div class="input-group">
                  <span class="input-group-text">
                    <i class="bi bi-envelope-fill"></i>
                  </span>

                  <%= f.email_field :email,
                        autofocus: true,
                        autocomplete: "email",
                        class: "form-control",
                        placeholder: "Digite seu e-mail" %>
                </div>

              </div>

              <div class="mb-3">

                <%= f.label :password, "Senha", class: "form-label fw-semibold" %>

                <% if @minimum_password_length %>
                  <small class="text-muted d-block mb-2">
                    Mínimo de <strong><%= @minimum_password_length %></strong> caracteres
                  </small>
                <% end %>

                <div class="input-group">
                  <span class="input-group-text">
                    <i class="bi bi-lock-fill"></i>
                  </span>

                  <%= f.password_field :password,
                        autocomplete: "new-password",
                        class: "form-control",
                        placeholder: "Digite sua senha" %>
                </div>

              </div>

              <div class="mb-4">

                <%= f.label :password_confirmation,
                      "Confirmar senha",
                      class: "form-label fw-semibold" %>

                <div class="input-group">
                  <span class="input-group-text">
                    <i class="bi bi-shield-lock-fill"></i>
                  </span>

                  <%= f.password_field :password_confirmation,
                        autocomplete: "new-password",
                        class: "form-control",
                        placeholder: "Confirme sua senha" %>
                </div>

              </div>

              <div class="d-grid mb-3">

                <%= f.submit "Criar Conta",
                      class: "btn btn-success btn-lg" %>

              </div>

            <% end %>

            <hr>

            <div class="text-center">
              <%= render "devise/shared/links" %>
            </div>

          </div>

        </div>

      </div>

    </div>
  </div>

</div>
