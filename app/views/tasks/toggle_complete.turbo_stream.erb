<% bucket = @task.bucket %>

<%= turbo_stream.remove "task_#{@task.id}" %>

<% if @task.completed %>
  <%= turbo_stream.prepend "done-tasks-#{bucket.id}" do %>
    <%= render "tasks/task", task: @task %>
  <% end %>
<% else %>
  <%= turbo_stream.prepend "open-tasks-#{bucket.id}" do %>
    <%= render "tasks/task", task: @task %>
  <% end %>
<% end %>

<%= turbo_stream.update "done-count-#{bucket.id}" do %>
  ✔️ Tarefas concluídas (<%= bucket.done_count %>)
<% end %>

<% if @task.completed && @task.recurrence.present? %>
  <% next_task = Task.find_by(
    bucket: bucket,
    title: @task.title,
    due_at: @task.due_at + (
      case @task.recurrence
      when "daily" then 1.day
      when "weekly" then 1.week
      when "monthly" then 1.month
      end
    )
  ) %>

  <% if next_task.present? %>
    <%= turbo_stream.prepend "open-tasks-#{bucket.id}" do %>
      <%= render "tasks/task", task: next_task %>
    <% end %>
  <% end %>
<% end %>

<%= turbo_stream.update "flash-container" do %>
  <%= render "shared/flashes", notice: @flash_container %>
<% end %>

<%= turbo_stream.update "task-status-button" do %>

  <%= button_to toggle_complete_action_plan_bucket_task_path(
        @task.bucket.action_plan,
        @task.bucket,
        @task
      ),
      method: :patch,
      data: {
        turbo_stream: true
      },
      class: "btn btn-sm #{@task.completed ? 'btn-success' : 'btn-outline-success'}" do %>

    <% if @task.completed %>
      <i class="bi bi-check-circle-fill"></i>
      Concluída
    <% else %>
      <i class="bi bi-circle"></i>
      Concluir
    <% end %>

  <% end %>

<% end %>
