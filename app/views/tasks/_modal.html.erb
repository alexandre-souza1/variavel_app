<div class="modal fade" id="taskModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Editar Tarefa</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <div class="row">

          <!-- COLUNA ESQUERDA -->
          <div class="col-md-7">

            <%= form_with model: [task.bucket.action_plan, task.bucket, task], local: true do |f| %>

              <!-- TÍTULO -->
              <div class="mb-3">
                <%= f.text_field :title, class: "form-control form-control-lg", placeholder: "Título da tarefa" %>
              </div>

              <!-- DESCRIÇÃO -->
              <div class="mb-3">
                <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Descrição..." %>
              </div>

              <!-- LABELS -->
              <div
                class="mb-3"
                data-controller="label"
                data-label-action-plan-id-value="<%= task.bucket.action_plan.id %>">

                <label>Labels</label>

                <input type="hidden" name="task[label_ids][]" value="">

                <select name="task[label_ids][]" multiple class="form-control" data-controller="tom-select">
                  <% task.bucket.action_plan.labels.each do |label| %>
                    <% if task.labels.include?(label) %>
                      <option
                        value="<%= label.id %>"
                        data-color="<%= label.color %>"
                        selected>
                        <%= label.name %>
                      </option>
                    <% else %>
                      <option
                        value="<%= label.id %>"
                        data-color="<%= label.color %>">
                        <%= label.name %>
                      </option>
                    <% end %>
                  <% end %>
                </select>

                <!-- CRIAR LABEL -->
                <div class="mt-2">
                  <small>Nova label:</small>

                  <div class="input-group">
                    <input type="text"
                          class="form-control form-control-sm"
                          placeholder="Nome"
                          autocomplete="off"
                          data-label-target="name">

                    <input type="color"
                          class="form-control form-control-sm form-control-color"
                          autocomplete="off"
                          data-label-target="color">

                    <button type="button"
                            class="btn btn-sm btn-outline-primary"
                            data-action="click->label#create">
                      +
                    </button>
                  </div>
                </div>
              </div>

              <!-- CHECKLIST -->
              <div class="mt-4" data-controller="task-checklist">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <h6 class="mb-0">Checklist</h6>
                  <div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-action="click->task-checklist#addItem">
                      + Adicionar item
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->task-checklist#clearAllItems" data-turbo-confirm="Limpar todos os itens?">
                      Limpar checklist
                    </button>
                  </div>
                </div>

                <div class="border rounded p-2 bg-light">
                  <%= f.fields_for :tasklist do |tasklist_form| %>
                    <%= tasklist_form.hidden_field :id %>
                    <div data-task-checklist-target="itemsContainer">
                      <% task.tasklist&.tasklist_items&.each do |item| %>
                        <%= tasklist_form.fields_for :tasklist_items, item do |item_form| %>
                          <div class="task-checklist-item mb-2 d-flex align-items-center gap-2">
                            <%= item_form.check_box :completed, class: "form-check-input" %>
                            <%= item_form.text_field :content, class: "form-control form-control-sm flex-grow-1", placeholder: "Item" %>
                            <%= item_form.hidden_field :id %>
                            <%= item_form.hidden_field :_destroy, value: false %>
                            <button type="button" class="btn btn-sm btn-link text-danger" data-action="click->task-checklist#removeItem"><i class="bi bi-trash"></i></button>
                          </div>
                        <% end %>
                      <% end %>
                    </div>

                    <template data-task-checklist-target="itemTemplate">
                      <div class="task-checklist-item mb-2 d-flex align-items-center gap-2">
                        <input type="hidden" name="task[tasklist_attributes][tasklist_items_attributes][NEW_RECORD][id]" value="">
                        <input type="hidden" name="task[tasklist_attributes][tasklist_items_attributes][NEW_RECORD][_destroy]" value="false">
                        <input type="checkbox" name="task[tasklist_attributes][tasklist_items_attributes][NEW_RECORD][completed]" value="1" class="form-check-input">
                        <input type="text" name="task[tasklist_attributes][tasklist_items_attributes][NEW_RECORD][content]" class="form-control form-control-sm flex-grow-1" placeholder="Novo item">
                        <button type="button" class="btn btn-sm btn-link text-danger" data-action="click->task-checklist#removeItem">🗑</button>
                      </div>
                    </template>
                  <% end %>
                </div>
              </div>

              <!-- DATAS -->
              <div class="row">
                <div class="col">
                  <%= f.label :start_at %>
                  <%= f.datetime_local_field :start_at, class: "form-control" %>
                </div>

                <div class="col">
                  <%= f.label :due_at %>
                  <%= f.datetime_local_field :due_at, class: "form-control" %>
                </div>
              </div>

              <!-- RECORRÊNCIA -->
              <div class="mb-3">
                <label>Repetir tarefa</label>

                <%= f.select :recurrence,
                  options_for_select([
                    ["Não repetir", nil],
                    ["Diariamente", "daily"],
                    ["Semanalmente", "weekly"],
                    ["Mensalmente", "monthly"]
                  ], task.recurrence),
                  {},
                  class: "form-control" %>
              </div>

              <div class="mb-3">
                <label>Responsáveis</label>

                <%= select_tag "task[user_ids][]",
                  options_from_collection_for_select(User.all, :id, :name, task.users.pluck(:id)),
                  multiple: true,
                  class: "form-control",
                  data: { controller: "tom-select-users" } %>
              </div>

              <div class="mt-3">
                <%= f.submit "Salvar", class: "btn btn-primary" %>
              </div>
          <% end %>
        </div>

          <!-- COLUNA DIREITA (COMENTÁRIOS) -->
          <div class="col-md-5 border-start">

            <h6>Comentários</h6>

            <%= turbo_stream_from "comments_task_#{task.id}" %>

            <!-- LISTA DE COMENTÁRIOS -->
            <div id="comments_task_<%= task.id %>"
              data-controller="comment-list"
              class="comments-box"
              style="max-height: 400px; overflow-y: auto;">
              <% task.comments.each do |comment| %>
                <%= render "comments/comment", comment: comment %>
              <% end %>
            </div>

            <hr>

            <!-- FORMULÁRIO -->
            <div id="new_comment_form_<%= task.id %>">
              <%= render "comments/form", task: task, comment: Comment.new %>
            </div>

          </div>

        </div>
      </div>

    </div>
  </div>
</div>
