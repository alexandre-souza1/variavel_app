<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-1">Dimensionamentos da Frota</h2>

      <p class="text-muted mb-0">
        Quinzenas usadas para montar a disponibilidade da frota.
      </p>
    </div>

    <%= link_to new_fleet_dimensioning_path,
                class: "btn btn-primary" do %>
      <i class="bi bi-plus-circle"></i>
      Novo Dimensionamento
    <% end %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <% if @fleet_dimensionings.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Nome</th>
                <th>Período</th>
                <th class="text-center">Carros</th>
                <th class="text-center">Vans</th>
                <th class="text-center">Vespertinas</th>
                <th class="text-center">AS</th>
                <th class="text-end"></th>
              </tr>
            </thead>

            <tbody>
              <% @fleet_dimensionings.each do |dimensioning| %>
                <tr>
                  <td><%= dimensioning.label %></td>
                  <td>
                    <%= l(dimensioning.start_date) %> a
                    <%= l(dimensioning.end_date) %>
                  </td>
                  <td class="text-center"><%= dimensioning.route_quantity %></td>
                  <td class="text-center"><%= dimensioning.van_quantity %></td>
                  <td class="text-center"><%= dimensioning.vespertina_quantity %></td>
                  <td class="text-center"><%= dimensioning.as_quantity %></td>
                  <td class="text-end">
                    <%= link_to edit_fleet_dimensioning_path(dimensioning),
                                class: "btn btn-sm btn-outline-primary" do %>
                      <i class="bi bi-pencil"></i>
                      Editar
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-calendar-range display-4 text-muted"></i>

          <h5 class="mt-3">Nenhum dimensionamento cadastrado</h5>

          <p class="text-muted">
            Cadastre a quinzena antes de criar a disponibilidade da frota.
          </p>

          <%= link_to new_fleet_dimensioning_path,
                      class: "btn btn-primary" do %>
            <i class="bi bi-plus-circle"></i>
            Novo Dimensionamento
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
  <div class="mt-2">
      <%= link_to fleet_availabilities_path,
                class: "btn btn-outline-secondary" do %>

      <i class="bi bi-arrow-left"></i>
      Voltar

    <% end %>
</div>
